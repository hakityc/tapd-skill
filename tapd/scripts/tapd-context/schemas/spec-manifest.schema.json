{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/flow/spec-manifest.schema.json",
  "title": "Flow Product Specification Manifest",
  "type": "object",
  "required": [
    "version",
    "spec_id",
    "title",
    "source",
    "scope",
    "acceptance"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "spec_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "repo_url",
        "ref",
        "document",
        "prototype_paths"
      ],
      "properties": {
        "repo_url": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "document": {
          "type": "string",
          "minLength": 1
        },
        "prototype_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decisions": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "priority",
          "statement"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]{2,}$"
          },
          "priority": {
            "enum": [
              "must",
              "should"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "provider",
        "space_id",
        "entity_type"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "space_id": {
          "type": "string",
          "minLength": 1
        },
        "entity_type": {
          "const": "requirement"
        },
        "external_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "published_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "draft",
            "reviewing",
            "approved",
            "changes-required"
          ]
        },
        "reviewed_ref": {
          "type": "string",
          "minLength": 1
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "approved"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "reviewed_ref",
              "decided_at"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
